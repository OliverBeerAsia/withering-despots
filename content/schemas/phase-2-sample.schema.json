{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://withering-despots.invalid/schemas/phase-2-sample.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "metadata",
    "characters",
    "claims",
    "chapters",
    "events",
    "attentionWindows",
    "interactionObjects",
    "dialogueGraphs",
    "epilogueSummaries",
    "locale"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "const": "phase-2-sample" },
    "metadata": { "$ref": "#/$defs/metadata" },
    "characters": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": { "$ref": "#/$defs/character" }
    },
    "claims": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/claim" }
    },
    "chapters": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/chapter" }
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/event" }
    },
    "attentionWindows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/attentionWindow" }
    },
    "interactionObjects": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/interactionObject" }
    },
    "dialogueGraphs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/dialogueGraph" }
    },
    "epilogueSummaries": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "$ref": "#/$defs/epilogueSummary" }
    },
    "locale": { "$ref": "#/$defs/locale" }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 3,
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "localeKey": {
      "type": "string",
      "minLength": 3,
      "pattern": "^[a-z][a-z0-9]*(?:[._][a-z0-9]+)*$"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "startMinute",
        "endMinute",
        "requiredLocales",
        "historicalReviewRequired",
        "culturalReviewRequired",
        "nativeRussianDialogueReviewRequired"
      ],
      "properties": {
        "status": { "const": "sample_not_final_dialogue" },
        "startMinute": { "type": "integer", "minimum": 0 },
        "endMinute": { "type": "integer", "minimum": 1 },
        "requiredLocales": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "prefixItems": [{ "const": "en" }],
          "items": false
        },
        "historicalReviewRequired": { "const": true },
        "culturalReviewRequired": { "const": true },
        "nativeRussianDialogueReviewRequired": { "const": true }
      }
    },
    "character": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "nameKey", "role", "historicalStatus", "initial"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "nameKey": { "$ref": "#/$defs/localeKey" },
        "role": { "enum": ["player", "manager", "patron"] },
        "historicalStatus": { "const": "fictional-composite" },
        "initial": { "$ref": "#/$defs/patronInitial" }
      }
    },
    "patronInitial": {
      "type": "object",
      "additionalProperties": false,
      "required": ["present", "trust", "agitation", "publicCertainty", "privatePressure"],
      "properties": {
        "present": { "type": "boolean" },
        "trust": { "type": "integer" },
        "agitation": { "type": "integer" },
        "publicCertainty": { "type": "integer" },
        "privatePressure": { "type": "integer" }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "speakerId",
        "context",
        "repeatable",
        "socialRisk",
        "contradicts",
        "historicalLedgerIds"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "speakerId": { "$ref": "#/$defs/id" },
        "context": { "enum": ["public", "private"] },
        "repeatable": { "type": "boolean" },
        "socialRisk": { "enum": ["none", "low", "high"] },
        "contradicts": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        },
        "historicalLedgerIds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "chapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "titleKey", "startsAt"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "titleKey": { "$ref": "#/$defs/localeKey" },
        "startsAt": { "type": "integer", "minimum": 0 }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "dueMinute",
        "priority",
        "effects",
        "historicalLedgerIds",
        "wordingPolicy"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "kind": { "enum": ["room", "broadcast", "telephone"] },
        "dueMinute": { "type": "integer", "minimum": 0 },
        "priority": { "type": "integer", "minimum": 0 },
        "effects": { "$ref": "#/$defs/effects" },
        "historicalLedgerIds": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "wordingPolicy": { "enum": ["none", "original-fictionalized"] }
      }
    },
    "attentionWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "eventId", "promptKey", "selectionMode", "timeoutMode", "offers"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "eventId": { "$ref": "#/$defs/id" },
        "promptKey": { "$ref": "#/$defs/localeKey" },
        "selectionMode": { "const": "primary-plus-fragment" },
        "timeoutMode": { "const": "none" },
        "offers": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/attentionOffer" }
        }
      }
    },
    "attentionOffer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "targetId", "labelKey", "gotoNodeId", "outcomes"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "targetId": { "$ref": "#/$defs/id" },
        "labelKey": { "$ref": "#/$defs/localeKey" },
        "gotoNodeId": { "$ref": "#/$defs/id" },
        "outcomes": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/attentionOutcome" }
        }
      }
    },
    "attentionOutcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["offerId", "outcome", "knowledgeId"],
      "properties": {
        "offerId": { "$ref": "#/$defs/id" },
        "outcome": { "enum": ["direct", "fragment", "secondhand", "missed"] },
        "knowledgeId": { "$ref": "#/$defs/id" },
        "sourceCharacterId": { "$ref": "#/$defs/id" },
        "sourceEventId": { "$ref": "#/$defs/id" }
      }
    },
    "interactionObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "labelKey", "initialState", "states"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "labelKey": { "$ref": "#/$defs/localeKey" },
        "initialState": { "$ref": "#/$defs/id" },
        "states": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        }
      }
    },
    "dialogueGraph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "entryNodeId", "nodes"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "entryNodeId": { "$ref": "#/$defs/id" },
        "nodes": {
          "type": "array",
          "minItems": 20,
          "items": { "$ref": "#/$defs/dialogueNode" }
        }
      }
    },
    "dialogueNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "speakerId", "textKey", "requires", "onEnter", "choices"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "speakerId": {
          "oneOf": [{ "$ref": "#/$defs/id" }, { "type": "null" }]
        },
        "textKey": { "$ref": "#/$defs/localeKey" },
        "requires": { "$ref": "#/$defs/conditions" },
        "onEnter": { "$ref": "#/$defs/effects" },
        "presentation": { "$ref": "#/$defs/dialoguePresentation" },
        "choices": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/dialogueChoice" }
        }
      }
    },
    "dialoguePresentation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["holdMs"],
      "properties": {
        "holdMs": { "type": "integer", "minimum": 10000, "maximum": 60000 }
      }
    },
    "dialogueChoice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "textKey", "kind", "requires", "effects"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "textKey": { "$ref": "#/$defs/localeKey" },
        "kind": { "enum": ["observe", "speak", "serve", "tune", "wait", "silence"] },
        "requires": { "$ref": "#/$defs/conditions" },
        "effects": { "$ref": "#/$defs/effects" }
      }
    },
    "conditions": {
      "type": "array",
      "items": { "$ref": "#/$defs/condition" }
    },
    "condition": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "conditions"],
          "properties": {
            "type": { "enum": ["all", "any"] },
            "conditions": { "$ref": "#/$defs/conditions" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "condition"],
          "properties": {
            "type": { "const": "not" },
            "condition": { "$ref": "#/$defs/condition" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "flagId", "value"],
          "properties": {
            "type": { "const": "flag" },
            "flagId": { "$ref": "#/$defs/id" },
            "value": { "type": "boolean" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "knowledgeId", "levels"],
          "properties": {
            "type": { "const": "knowledge" },
            "knowledgeId": { "$ref": "#/$defs/id" },
            "levels": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "enum": ["direct", "fragment", "secondhand"] }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "objectId", "state"],
          "properties": {
            "type": { "const": "object-state" },
            "objectId": { "$ref": "#/$defs/id" },
            "state": { "$ref": "#/$defs/id" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "claimId"],
          "properties": {
            "type": { "const": "claim-known" },
            "claimId": { "$ref": "#/$defs/id" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "patronId", "metric", "operator", "value"],
          "properties": {
            "type": { "const": "patron-metric" },
            "patronId": { "$ref": "#/$defs/id" },
            "metric": { "enum": ["trust", "agitation", "publicCertainty", "privatePressure"] },
            "operator": { "enum": ["gte", "lte"] },
            "value": { "type": "number" }
          }
        }
      ]
    },
    "effects": {
      "type": "array",
      "items": { "$ref": "#/$defs/effect" }
    },
    "effect": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "minutes", "reason"],
          "properties": {
            "type": { "const": "advance-time" },
            "minutes": { "type": "integer", "minimum": 0, "maximum": 12 },
            "reason": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "flagId", "value"],
          "properties": {
            "type": { "const": "set-flag" },
            "flagId": { "$ref": "#/$defs/id" },
            "value": { "type": "boolean" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "patronId", "metric", "amount"],
          "properties": {
            "type": { "const": "adjust-patron" },
            "patronId": { "$ref": "#/$defs/id" },
            "metric": { "enum": ["trust", "agitation", "publicCertainty", "privatePressure"] },
            "amount": { "type": "number" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "fromId", "toId", "amount"],
          "properties": {
            "type": { "const": "adjust-relationship" },
            "fromId": { "$ref": "#/$defs/id" },
            "toId": { "$ref": "#/$defs/id" },
            "amount": { "type": "number" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "knowledgeId", "provenance"],
          "properties": {
            "type": { "const": "add-knowledge" },
            "knowledgeId": { "$ref": "#/$defs/id" },
            "provenance": { "enum": ["direct", "fragment", "secondhand"] },
            "sourceCharacterId": { "$ref": "#/$defs/id" },
            "sourceEventId": { "$ref": "#/$defs/id" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "claimId", "provenance"],
          "properties": {
            "type": { "const": "add-claim" },
            "claimId": { "$ref": "#/$defs/id" },
            "provenance": { "enum": ["direct", "fragment", "secondhand"] },
            "sourceCharacterId": { "$ref": "#/$defs/id" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "firstClaimId", "secondClaimId"],
          "properties": {
            "type": { "const": "mark-contradiction" },
            "firstClaimId": { "$ref": "#/$defs/id" },
            "secondClaimId": { "$ref": "#/$defs/id" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "objectId", "state"],
          "properties": {
            "type": { "const": "set-object-state" },
            "objectId": { "$ref": "#/$defs/id" },
            "state": { "$ref": "#/$defs/id" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "eventId", "status"],
          "properties": {
            "type": { "const": "set-event-status" },
            "eventId": { "$ref": "#/$defs/id" },
            "status": { "enum": ["pending", "announced", "complete", "missed"] }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "windowId"],
          "properties": {
            "type": { "const": "open-attention" },
            "windowId": { "$ref": "#/$defs/id" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "chapterId"],
          "properties": {
            "type": { "const": "set-chapter" },
            "chapterId": { "$ref": "#/$defs/id" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "nodeId"],
          "properties": {
            "type": { "const": "goto" },
            "nodeId": { "$ref": "#/$defs/id" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "factId"],
          "properties": {
            "type": { "const": "append-epilogue-fact" },
            "factId": { "$ref": "#/$defs/id" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "summaryId"],
          "properties": {
            "type": { "const": "set-summary" },
            "summaryId": { "$ref": "#/$defs/id" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": { "const": "complete" }
          }
        }
      ]
    },
    "epilogueSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "titleKey", "requires", "lines"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "titleKey": { "$ref": "#/$defs/localeKey" },
        "requires": { "$ref": "#/$defs/conditions" },
        "lines": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/summaryLine" }
        }
      }
    },
    "summaryLine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["textKey", "requires"],
      "properties": {
        "textKey": { "$ref": "#/$defs/localeKey" },
        "requires": { "$ref": "#/$defs/conditions" }
      }
    },
    "locale": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "entries"],
      "properties": {
        "id": { "const": "en" },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/localeEntry" }
        }
      }
    },
    "localeEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "text"],
      "properties": {
        "key": { "$ref": "#/$defs/localeKey" },
        "text": { "type": "string", "minLength": 1, "maxLength": 220 },
        "allowUnusedReason": { "type": "string", "minLength": 1 }
      }
    }
  }
}
