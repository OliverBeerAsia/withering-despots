{
  "name": "withering-despots",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "corepack pnpm test:content && corepack pnpm typecheck && vite build",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/unit",
    "test:content": "vitest run tests/content",
    "test:simulation": "vitest run tests/simulation",
    "test:e2e": "playwright test tests/e2e",
    "test:visual": "playwright test tests/visual",
    "check": "corepack pnpm format:check && corepack pnpm lint && corepack pnpm typecheck && corepack pnpm test && corepack pnpm test:content && corepack pnpm test:simulation && corepack pnpm build && corepack pnpm test:e2e && corepack pnpm test:visual"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "pixi.js": "8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@types/pngjs": "^6.0.5",
    "eslint": "10.7.0",
    "pngjs": "^7.0.0",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
